# Copy this file to .env and fill in your values.

# IMAP server settings
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USERNAME=your_email@example.com
IMAP_PASSWORD=your_app_password

# Mailbox to scan (usually INBOX)
IMAP_MAILBOX=INBOX

# Optional keyword filters for matching ACR emails
ACR_KEYWORDS=Academic Consideration Request,ACR

# Performance controls
# IMAP_DAYS_BACK: only scan emails from the last N days (set 0 to scan all)
IMAP_DAYS_BACK=14
# IMAP_MAX_EMAILS: max number of newest emails to process each run (set 0 for no cap)
IMAP_MAX_EMAILS=200
# IMAP_UNSEEN_ONLY: if true, only scan unread emails
IMAP_UNSEEN_ONLY=true

# Output file path
EXCEL_OUTPUT=outputs/acr_students.xlsx
